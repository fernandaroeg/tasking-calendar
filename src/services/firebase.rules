rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'master_admin');
    }

    function isMasterAdmin() {
      return isAuthenticated() && getUserRole() == 'master_admin';
    }

    function isApproved() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/pre_approved_users/$(request.auth.token.email.lower()));
    }

    // Pre-approved list rules
    match /pre_approved_users/{email} {
      allow read: if isAuthenticated() && isApproved();
      allow create, update: if (isAdmin() && request.resource.data.role != 'master_admin') || isMasterAdmin();
      allow delete: if (isAdmin() && resource.data.role != 'master_admin') || isMasterAdmin();
    }

    // User profiles rules
    match /users/{userId} {
      allow read: if isAuthenticated() && isApproved();
      allow create: if isAuthenticated() && 
        exists(/databases/$(database)/documents/pre_approved_users/$(request.auth.token.email.lower())) &&
        request.resource.data.role == get(/databases/$(database)/documents/pre_approved_users/$(request.auth.token.email.lower())).data.role;
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || request.resource.data.role == get(/databases/$(database)/documents/pre_approved_users/$(request.auth.token.email.lower())).data.role))
        || (isAdmin() && resource.data.role != 'master_admin' && request.resource.data.role != 'master_admin')
        || isMasterAdmin()
      );
    }

    // Projects rules
    match /projects/{projectId} {
      allow read: if isAdmin() || (isAuthenticated() && isApproved() && request.auth.token.email.lower() in resource.data.assignedUsers);
      allow write: if isAdmin();
    }

    // Tasks rules
    match /tasks/{taskId} {
      // Helper to check project membership
      function isMemberOfProject(projId) {
        return request.auth.token.email.lower() in get(/databases/$(database)/documents/projects/$(projId)).data.assignedUsers;
      }

      allow read: if isAdmin() || (isAuthenticated() && isApproved() && isMemberOfProject(resource.data.projectId));
      
      allow create: if isAdmin() || (isAuthenticated() && isApproved() && isMemberOfProject(request.resource.data.projectId));
      
      allow update: if isAdmin() || (isAuthenticated() && isApproved() && isMemberOfProject(resource.data.projectId));
      
      allow delete: if isAdmin() || (isAuthenticated() && isApproved() && isMemberOfProject(resource.data.projectId));
    }
  }
}
